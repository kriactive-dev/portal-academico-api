{
  "name": "ya-academico",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:admin": "turbo run dev --filter=admin",
    "dev:portal": "turbo run dev --filter=portal",
    "admin": "turbo run dev --filter=admin",
    "portal": "turbo run dev --filter=portal",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "turbo": "^2.5.8"
  },
  "packageManager": "bun@1.2.20"
}
