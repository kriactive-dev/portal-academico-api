APP_NAME="YA Academico API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database Configuration ---
# SQLite (default for local development)
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# MySQL (production)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=ya_academico
# DB_USERNAME=root
# DB_PASSWORD=

# PostgreSQL (alternative)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=ya_academico
# DB_USERNAME=root
# DB_PASSWORD=

# --- Session (stateless API - no session storage needed) ---
SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Broadcast ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# --- Cache ---
CACHE_STORE=database

# --- Mail ---
MAIL_MAILER=log
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="noreply@ya-academico.com"
# MAIL_FROM_NAME="${APP_NAME}"

# --- Sanctum ---
SANCTUM_STATEFUL_DOMAINS=
SESSION_DOMAIN=null

# --- Frontend URLs (CORS) ---
FRONTEND_ADMIN_URL=http://localhost:3000
FRONTEND_PORTAL_URL=http://localhost:3001

# --- File Uploads ---
FILESYSTEM_DISK=local
UPLOAD_MAX_SIZE=10240

# --- Rate Limiting ---
API_RATE_LIMIT_PER_MINUTE=60
